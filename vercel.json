{
  "buildCommand": "npx expo export --platform web",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(Twitterbot|facebookexternalhit|Slackbot|LinkedInBot|Discordbot|LINE|Pinterestbot|Applebot|Googlebot|bingbot|TelegramBot|Whatsapp).*"
        }
      ],
      "destination": "/api/ogp?path=/:path*"
    },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/ad.html",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/((?!ad\\.html).*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://adm.shinobi.jp https://js.stripe.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://*.shinobi.jp https://*.microad.net https://*.googleadservices.com https://*.stripe.com; font-src 'self'; connect-src 'self' https://*.shinobi.jp https://api.stripe.com; frame-src 'self' data: https://*.shinobi.jp https://*.doubleclick.net https://checkout.stripe.com https://js.stripe.com; frame-ancestors 'self'"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}
